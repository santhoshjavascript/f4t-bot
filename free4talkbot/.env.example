# ============================================================
#  GicellBot — Environment Variables
#  Copy file ini jadi ".env", lalu isi dengan key kamu.
#  JANGAN commit file ".env" ke GitHub!
# ============================================================

# ── GROQ API (Speech-to-Text / Whisper) ─────────────────────
# Daftar gratis di https://console.groq.com
# Untuk multiple key (rotation), pisahkan dengan koma tanpa spasi
GROQ_API_KEYS=gsk_REPLACE_ME_KEY1,gsk_REPLACE_ME_KEY2

# ── NVIDIA NIM API (AI Chat) ─────────────────────────────────
# Daftar gratis di https://build.nvidia.com
# Untuk multiple key (rotation), pisahkan dengan koma tanpa spasi
NIM_API_KEYS=nvapi-REPLACE_ME_KEY1,nvapi-REPLACE_ME_KEY2

# ── ROOM AUTO-JOIN (Opsional) ────────────────────────────────
# URL room Free4Talk yang ingin di-auto-join saat bot start
# Kosongkan jika ingin set manual via dashboard
ROOM_URL=

# ── BOT IDENTITY ─────────────────────────────────────────────
BOT_NAME=GicellBot
